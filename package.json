{
  "name": "universal-remote-card",
  "version": "1.0.0",
  "description": "Universal Remote Card for Home Assistant – Fire TV, Android TV, Apple TV, and generic media players",
  "type": "module",
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "fire-tv",
    "android-tv",
    "apple-tv",
    "remote"
  ],
  "author": "Universal Remote Card Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhartiNitish-1707/Universal-Remote"
  },
  "main": "./dist/universal-remote-card.js",
  "files": [
